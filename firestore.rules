rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - The name of the product
    //   - price: string (required) - The price of the product
    //   - image: string (required) - The URL of the product image
    //   - description: string (required) - A description of the product
    //   - category: string (required) - upholstery or accessories
    //   - createdAt: timestamp (required) - The date and time the product was added
    //   - badge: string (optional) - A badge for the product
    //   - images: list (optional) - Gallery images
    //   - colors: list (optional) - Available hex colors
    //
    // Collection: settings
    // Document ID: 'site'
    // Fields:
    //   - heroImage: string
    //   - logoText: string
    //   - logoSubtext: string
    //   - facebookUrl: string
    //   - whatsappNumber: string
    //   - instagramUrl: string
    //   - phoneNumber: string
    //   - location: string
    //   - locationUrl: string
    //   - paymentMethods: list of maps
    //
    // Collection: reviews
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - car: string (optional)
    //   - text: string (required)
    //   - stars: int (required)
    //   - initials: string (required)
    //   - color: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: auth.uid
    // Fields:
    //   - role: string (required) - 'admin' or 'user'
    //   - email: string (required) - The user's email
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "youssefrohayem17@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'price', 'image', 'category', 'description', 'createdAt']) &&
             hasOnlyAllowedFields(['name', 'price', 'image', 'category', 'description', 'createdAt', 'badge', 'images', 'colors']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.image is string && data.image.matches("^https?://.*") &&
             data.category in ['upholstery', 'accessories'] &&
             data.description is string && data.description.size() < 2000 &&
             data.createdAt is timestamp &&
             (!('badge' in data) || (data.badge is string && data.badge.size() < 50)) &&
             (!('images' in data) || (data.images is list && data.images.size() <= 10)) &&
             (!('colors' in data) || (data.colors is list && data.colors.size() <= 10));
    }

    function isValidSettings(data) {
      return hasRequiredFields(['heroImage', 'logoText', 'logoSubtext', 'whatsappNumber', 'paymentMethods']) &&
             data.heroImage is string && data.heroImage.matches("^https?://.*") &&
             data.logoText is string && data.logoText.size() < 50 &&
             data.logoSubtext is string && data.logoSubtext.size() < 50 &&
             data.whatsappNumber is string && data.whatsappNumber.size() < 20 &&
             data.paymentMethods is list && data.paymentMethods.size() <= 10;
    }

    function isValidReview(data) {
      return hasRequiredFields(['name', 'text', 'stars', 'initials', 'color', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.stars is int && data.stars >= 1 && data.stars <= 5 &&
             data.initials is string && data.initials.size() <= 5 &&
             data.color is string && data.color.matches("^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$") &&
             data.createdAt is timestamp &&
             (!('car' in data) || (data.car is string && data.car.size() < 100));
    }

    function isValidUser(data) {
      return hasRequiredFields(['email', 'role']) &&
             data.email is string && data.email.size() < 200 &&
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.matches("^https?://.*")));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (isAdmin() || (request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
